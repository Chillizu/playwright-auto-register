{
  "description": "NVIDIA 专用预设：仅使用 kimi-k2-instruct / glm4.7 / deepseek-v3.2",
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "enabled_providers": ["nvidia"],

  "agents": {
    "sisyphus": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "hephaestus": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/deepseek-ai/deepseek-v3.2", "nvidia/z-ai/glm4.7"]
    },
    "prometheus": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"],
      "prompt_append": "Leverage quick agents heavily for simple tasks, always run them in parallel."
    },
    "oracle": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "librarian": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "explore": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "metis": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "momus": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "atlas": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "multimodal-looker": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/deepseek-ai/deepseek-v3.2"]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "ultrabrain": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "deep": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "artistry": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "quick": {
      "model": "nvidia/moonshotai/kimi-k2-instruct",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "unspecified-low": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"]
    },
    "unspecified-high": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/z-ai/glm4.7", "nvidia/moonshotai/kimi-k2-instruct"]
    },
    "writing": {
      "model": "nvidia/deepseek-ai/deepseek-v3.2",
      "fallback_models": ["nvidia/moonshotai/kimi-k2-instruct", "nvidia/deepseek-ai/deepseek-v3.2"]
    }
  },

  "background_task": {
    "providerConcurrency": {
      "nvidia": 15
    },
    "modelConcurrency": {
      "nvidia/moonshotai/kimi-k2-instruct": 8,
      "nvidia/z-ai/glm-4.7": 8,
      "nvidia/deepseek-ai/deepseek-v3.2": 6
    }
  }
}
