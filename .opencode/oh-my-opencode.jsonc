{
  "description": "Yumeyuki split-provider preset: separate Anthropic/OpenAI/Google routes without overriding original providers.",
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

  "enabled_providers": ["yumeyuki-anthropic", "yumeyuki-openai", "yumeyuki-google"],

  "agents": {
    "sisyphus": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6",
      "fallback_models": ["yumeyuki-anthropic/claude-sonnet-4-5"]
    },
    "hephaestus": {
      "model": "yumeyuki-openai/gpt-5.1-codex-mini",
      "fallback_models": ["yumeyuki-openai/qwen/qwen3-coder-480b-a35b-instruct"]
    },
    "prometheus": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6",
      "fallback_models": ["yumeyuki-google/gemini-3.1-pro-preview"]
    },
    "oracle": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6",
      "fallback_models": ["yumeyuki-google/gemini-3.1-pro-preview"]
    },
    "librarian": {
      "model": "yumeyuki-google/gemini-3.1-pro-preview",
      "fallback_models": ["yumeyuki-google/gemini-3-flash-preview"]
    },
    "explore": {
      "model": "yumeyuki-google/gemini-3.1-flash-lite-preview",
      "fallback_models": ["yumeyuki-openai/deepseek-ai/DeepSeek-V3.2"]
    },
    "metis": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-5"
    },
    "momus": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6"
    },
    "atlas": {
      "model": "yumeyuki-openai/qwen/qwen3.5-397b-a17b",
      "fallback_models": ["yumeyuki-openai/moonshotai/kimi-k2.5"]
    }
  },

  "categories": {
    "visual-engineering": {
      "model": "yumeyuki-google/gemini-3.1-pro-preview",
      "fallback_models": ["yumeyuki-google/gemini-3-flash-preview"]
    },
    "ultrabrain": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6"
    },
    "deep": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6",
      "fallback_models": ["yumeyuki-openai/gpt-5.1-codex-mini"]
    },
    "artistry": {
      "model": "yumeyuki-openai/gemma-4-31b-it"
    },
    "quick": {
      "model": "yumeyuki-openai/qwen/qwen3.5-397b-a17b",
      "fallback_models": [
        "yumeyuki-openai/deepseek-ai/DeepSeek-R1",
        "yumeyuki-openai/moonshotai/kimi-k2.5"
      ]
    },
    "unspecified-low": {
      "model": "yumeyuki-openai/deepseek-ai/DeepSeek-V3.2"
    },
    "unspecified-high": {
      "model": "yumeyuki-anthropic/claude-sonnet-4-6"
    },
    "writing": {
      "model": "yumeyuki-openai/gemma-4-31b-it"
    }
  },

  "background_task": {
    "providerConcurrency": {
      "yumeyuki-anthropic": 4,
      "yumeyuki-openai": 6,
      "yumeyuki-google": 6
    }
  }
}
